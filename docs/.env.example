# PostHog analytics for the docs site (VitePress).
#
# Copy this to `docs/.env` to enable analytics locally. Both vars are PUBLIC_*,
# so Vite inlines their values into the static build at build time -- they are
# NOT read at serve time. That means the value must exist wherever the build
# runs: here for local dev, or as a GitHub Actions repo variable in CI (see
# .github/workflows/docs.yml). In CI the token is a repo *variable*, not a
# secret, because it is public by design and ships to every browser.
#
# Leave the token blank to keep analytics off (the default, and usually what you
# want locally). VitePress reads .env only at startup -- restart `bun run
# docs:dev` after editing it.

# Project API key. Gates whether analytics runs. Use a dev/test project locally.
PUBLIC_POSTHOG_PROJECT_TOKEN=

# Ingestion host. Optional -- defaults to https://us.i.posthog.com when unset.
PUBLIC_POSTHOG_HOST=
