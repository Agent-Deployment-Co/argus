{
  "name": "@agentdeploymentco/argus",
  "version": "0.1.14",
  "description": "Audit your Claude Code, Codex, and Gemini CLI usage: tokens over time, skill/plugin/MCP-server attribution, and per-session summaries. Reads local transcripts; emits a self-contained HTML dashboard.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bash scripts/dev.sh",
    "dev:web": "vite --config web/vite.config.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p web --noEmit",
    "bench:cache": "bun run scripts/bench-cache.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "build:compile": "bun run build:web && bun build --compile src/cli.ts --outfile dist/argus",
    "bump-version": "bun run scripts/bump-version.ts",
    "get-version": "bun run scripts/get-version.ts",
    "build:npm": "bun run scripts/build-npm-packages.ts",
    "desktop:stage": "bun run scripts/stage-desktop-sidecar.ts --build",
    "desktop:dev": "bun run scripts/build-desktop.ts dev",
    "desktop:build": "bun run scripts/build-desktop.ts build",
    "desktop:dmg": "bun run scripts/build-desktop.ts dmg",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@agentdeploymentco/argus-schema": "github:Agent-Deployment-Co/argus-schema#v0.3.0",
    "@hono/node-server": "^2.0.5",
    "citty": "^0.2.2",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "^1.3.14",
    "chart.js": "^4.5.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitepress": "^2.0.0-alpha.17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agent-Deployment-Co/argus.git"
  }
}